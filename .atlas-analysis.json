  "keyFeatures": [
    "Automatic resistance control for spin bikes",
    "ERG mode for power-based training",
    "BLE connectivity with FTMS, Cycling Power, and CSC services",
    "Compatible with Zwift, TrainerRoad, and other cycling apps",
    "Power calibration and correction system",
    "Web-based configuration interface",
    "OTA firmware updates",
    "Custom BLE characteristics for remote control",
    "3D-printable hardware for multiple bike models",
    "Companion mobile app for iOS and Android"
  ],
  "publicApiSurface": [
    "FTMS (Fitness Machine Service) - Standard BLE service for trainer control",
    "Cycling Power Service - BLE service for power measurement",
    "Cycling Speed and Cadence Service - BLE service for speed/cadence data",
    "Custom Characteristic (UUID: 77776277-7877-7774-4466-896665500001) - Direct parameter control",
    "Web Configuration Interface - HTML/JavaScript interface on port 80",
    "HTTP REST endpoints for settings and status",
    "WebSocket API for real-time logging and monitoring",
    "Power Table API - Calibration data management",
    "ERG Mode Control - Power-based resistance management",
    "OTA Update Service - Firmware update over HTTP"
  ]
